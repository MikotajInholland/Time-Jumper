APP_NAME="Time Jumper API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database: local by default; for cloud set DB_HOST to your managed DB URL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=timejumper
DB_USERNAME=root
DB_PASSWORD=

# For Docker Compose use DB_HOST=mysql and the same credentials as in docker-compose

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
